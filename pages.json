{
	"easycom": {
		"autoscan": true,
		"custom": {
			// uni-ui 规则如下配置
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页"
				// "navigationStyle": "custom"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationBarTitleText": "我的"
			}
		},
		{
			"path": "pages/sub/sub",
			"style": {
				"navigationBarTitleText": "订阅"
			}
		},
		{
			"path": "pages/explore-shop/explore-shop",
			"style": {
				"navigationBarTitleText": "选择门店"
			}
		},
		{
			"path" : "pages/city-index/city-index",
			"style" : 
			{
				"navigationBarTitleText" : "城市索引"
			}
		},
		{
			"path" : "pages/shop-info/shop-info",
			"style" : 
			{
				"navigationBarTitleText" : "门店详情"
			}
		},
		{
			"path" : "pages/search-shop/search-shop",
			"style" : 
			{
				"navigationBarTitleText" : "搜索门店"
			}
		}
	],
	"tabBar": {
		"list": [
			{
				"text": "首页",
				"pagePath": "pages/index/index",
				"iconPath": "./static/Jigsaw.png",
				"selectedIconPath": "./static/Jigsaw-select.png"
				
			},
			{
				"text": "订阅",
				"pagePath": "pages/sub/sub",
				"iconPath": "./static/Alarm Clock.png",
				"selectedIconPath": "./static/Alarm Clock-select.png"
			},
			{
				"text": "我的",
				"pagePath": "pages/my/my",
				"iconPath": "./static/User.png",
				"selectedIconPath": "./static/User-select.png"
			}
		],
		"selectedColor": "#515151",
		"color": "#cdcdcd"
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	}
}